SECRET_KEY=wger-docker-supersecret-key-1234567890!@#$%^&*(-_)
SIGNING_KEY=testbot-insecure-signing-key-not-for-prod-wger
SITE_URL=http://localhost
TIME_ZONE=Europe/Berlin
TZ=Europe/Berlin

# Django DB connection (settings.main reads DJANGO_DB_* not PS_DATABASE_URI)
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_DATABASE=wger
DJANGO_DB_USER=wger
DJANGO_DB_PASSWORD=wger
DJANGO_DB_HOST=db
DJANGO_DB_PORT=5432

# Postgres service credentials
POSTGRES_USER=wger
POSTGRES_PASSWORD=wger
POSTGRES_DB=wger

# In-process cache — no Redis needed
DJANGO_CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache

# App settings
DJANGO_DEBUG=False
DJANGO_PERFORM_MIGRATIONS=True
WGER_USE_GUNICORN=True
WGER_PORT=8000
WGER_INSTANCE=https://wger.de
ALLOW_REGISTRATION=True
ALLOW_GUEST_USERS=False
ALLOW_UPLOAD_VIDEOS=True
MIN_ACCOUNT_AGE_TO_TRUST=21
DOWNLOAD_INGREDIENTS_FROM=WGER

# Skip slow first-boot sync tasks (exercises/images/videos from wger.de)
SYNC_EXERCISES_ON_STARTUP=False
DOWNLOAD_EXERCISE_IMAGES_ON_STARTUP=False
DOWNLOAD_EXERCISE_VIDEOS_ON_STARTUP=False
LOAD_ONLINE_FIXTURES_ON_STARTUP=False

# Disable Celery — no workers in testbot setup
USE_CELERY=False

# Disable brute-force lockout — testbot makes repeated auth calls
AXES_ENABLED=False

# Token lifetimes
ACCESS_TOKEN_LIFETIME=10
REFRESH_TOKEN_LIFETIME=2880
